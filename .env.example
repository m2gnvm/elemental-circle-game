# ── Copy this file to .env and fill in real values ────────────────────────────
# .env is gitignored. Never commit real secrets.
# In production all values are set in Coolify's Environment Variables UI.

# ── Frontend domain (Flutter UI) ──────────────────────────────────────────────
# Used by the backend for CORS — browser requests come FROM this origin.
ALLOWED_ORIGINS=["https://elemental-circle.kamilstankowski.pl"]

# ── API domain (FastAPI backend) ──────────────────────────────────────────────
# Baked into the Flutter web build so the browser knows where to send requests.
API_URL=https://ec-api.kamilstankowski.pl
API_WS_URL=wss://ec-api.kamilstankowski.pl

# ── Managed PostgreSQL (from Coolify PostgreSQL service) ──────────────────────
# Copy the connection string from Coolify → your PostgreSQL service → Connection
DATABASE_URL=postgresql://user:password@host:5432/dbname

# ── Managed Redis (from Coolify Redis service) ────────────────────────────────
# Copy the connection string from Coolify → your Redis service → Connection
REDIS_URL=redis://:password@host:6379

# ── Backend ───────────────────────────────────────────────────────────────────
# Generate with: python3 -c "import secrets; print(secrets.token_hex(32))"
SECRET_KEY=CHANGE_ME_LONG_RANDOM_SECRET
ACCESS_TOKEN_EXPIRE_MINUTES=30

# ── Local dev overrides (uncomment when running docker compose locally) ────────
# DATABASE_URL=postgresql://gameuser:gamepass123@localhost/elemental_circle
# REDIS_URL=redis://localhost:6379
# ALLOWED_ORIGINS=["*"]
# API_URL=http://localhost:8000
# API_WS_URL=ws://localhost:8000
